{
  "checks": [
    {
      "name": "ha-api-health",
      "target": "${HA_API_URL}/api/",
      "method": "GET",
      "expected_status": 200,
      "timeout_s": 5,
      "capability_id": "cap-ha-control-plane-reachable",
      "capability_name": "Home Assistant control plane reachability",
      "business_impact": "TestBot cannot read or influence the home runtime if the HA API is unavailable.",
      "severity_if_broken": "critical",
      "headers": {
        "Authorization": "Bearer ${HA_API_SECRET}",
        "Content-Type": "application/json"
      }
    },
    {
      "name": "ha-api-readiness",
      "target": "${HA_API_URL}/api/config",
      "method": "GET",
      "expected_status": 200,
      "timeout_s": 5,
      "capability_id": "cap-ha-context-readiness",
      "capability_name": "Home Assistant context readiness",
      "business_impact": "Automation context and entity metadata are unavailable, degrading grounded responses and control actions.",
      "severity_if_broken": "high",
      "headers": {
        "Authorization": "Bearer ${HA_API_SECRET}",
        "Content-Type": "application/json"
      }
    },
    {
      "name": "ollama-api-ready",
      "target": "${OLLAMA_BASE_URL}/api/tags",
      "method": "GET",
      "expected_status": 200,
      "timeout_s": 5,
      "capability_id": "cap-ollama-model-runtime-ready",
      "capability_name": "Ollama model runtime readiness",
      "business_impact": "Knowing-mode responses cannot be generated when model serving is unavailable.",
      "severity_if_broken": "critical"
    },
    {
      "name": "ollama-embedding-ready",
      "target": "${OLLAMA_BASE_URL}/api/tags",
      "method": "GET",
      "expected_status": 200,
      "timeout_s": 5,
      "capability_id": "cap-ollama-embedding-runtime-ready",
      "capability_name": "Ollama embedding runtime readiness",
      "business_impact": "Retrieval and grounding pipelines cannot build semantic context when embeddings are unavailable.",
      "severity_if_broken": "high"
    }
  ]
}
